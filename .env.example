# ============================================================
# ArcHandshake Environment Variables — copy to .env and fill in
# ============================================================

# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=

# Gemini AI API Key (for real Vision-based deliverable verification — get from https://aistudio.google.com/)
GEMINI_API_KEY=

# Circle Developer Console API Key
CIRCLE_API_KEY=

# Arc Network RPC configuration
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002

# Bot private key (EVM private key used for on-chain transactions)
BOT_PRIVATE_KEY=

# Bot wallet public address (derived from BOT_PRIVATE_KEY — printed on startup)
NEXT_PUBLIC_BOT_WALLET_ADDRESS=

# ArcHandshake Smart Contract Addresses (Arc Testnet — auto-filled with deployed defaults)
NEXT_PUBLIC_ESCROW_ADDRESS=0x40aC372780Db3772E1810A515b8D0b71081902be
NEXT_PUBLIC_TREASURY_ADDRESS=0x29984fd25B15Cd271e4ebAD350a2Ca2269a65304
# USDC token address on Arc Testnet (native USDC — confirm from https://testnet.arcscan.app)
NEXT_PUBLIC_USDC_ADDRESS=

# Next.js Web App URL (must be HTTPS for Telegram Mini Apps, e.g. via ngrok or cloudflare tunnel)
NEXT_PUBLIC_WEB_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
